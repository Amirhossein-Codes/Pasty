                                </path>
                            </g>
                        </g>
                    </svg>
                </button>
                <textarea title="Enter your pasty!" placeholder="Enter your content here..." tabindex="" name="content"
                    id="content" required="true"></textarea>
                <div class="btns">
                    <div class="left">

                        <div class="lock"><svg width="64px" height="64px" viewBox="-2.5 -2.5 44 44" fill="none"
                                xmlns="http://www.w3.org/2000/svg">
                                <path fill-rule="evenodd" clip-rule="evenodd"
                                    d="M5.25 10.0546V8C5.25 4.27208 8.27208 1.25 12 1.25C15.7279 1.25 18.75 4.27208 18.75 8V10.0546C19.8648 10.1379 20.5907 10.348 21.1213 10.8787C22 11.7574 22 13.1716 22 16C22 18.8284 22 20.2426 21.1213 21.1213C20.2426 22 18.8284 22 16 22H8C5.17157 22 3.75736 22 2.87868 21.1213C2 20.2426 2 18.8284 2 16C2 13.1716 2 11.7574 2.87868 10.8787C3.40931 10.348 4.13525 10.1379 5.25 10.0546ZM6.75 8C6.75 5.10051 9.10051 2.75 12 2.75C14.8995 2.75 17.25 5.10051 17.25 8V10.0036C16.867 10 16.4515 10 16 10H8C7.54849 10 7.13301 10 6.75 10.0036V8ZM12 13.25C12.4142 13.25 12.75 13.5858 12.75 14V18C12.75 18.4142 12.4142 18.75 12 18.75C11.5858 18.75 11.25 18.4142 11.25 18V14C11.25 13.5858 11.5858 13.25 12 13.25Z"
                                    fill="cyan" />
                            </svg>
                            <input class="passwd" type="text" name="passwd" placeholder="Optional Password..."
                                title="Secret key">
                        </div>
                        <div class="expire">
                            <svg width="64" height="64" viewBox="-2.5 -2.5 32 32" xmlns="http://www.w3.org/2000/svg">
                                <g fill="cyan">
                                    <path
                                        d="M12.144 1.157a8 8 0 10-.709 14.068 1 1 0 00-.858-1.806 6 6 0 112.86-7.955 1 1 0 001.814-.845 8 8 0 00-3.107-3.462z" />
                                    <path
                                        d="M7 5a1 1 0 112 0v4a1 1 0 01-.553.894l-2 1a1 1 0 11-.894-1.788L7 8.382V5zm9 10a1 1 0 11-2 0 1 1 0 012 0zm-1-7a1 1 0 00-1 1v3a1 1 0 102 0V9a1 1 0 00-1-1z" />
                                </g>
                            </svg>
                            <select name="duration" id="duration" class="duration" title="Expiration duration">
                                <option value="60">1 minutes</option>
                                <option value="600">10 minutes</option>
                                <option value="3600">1 hour</option>
                                <option value="86400">1 day</option>
                                <option value="604800">1 week</option>
                            </select>
                        </div>

                    </div>


                    <div class="right"><input class="clear" type="reset" value="Clear"><button class="copy"
                            type="button">Copy</button><button class="save" type="submit">Save</button>
                    </div>
                </div>
            </form>
        </fieldset>
    </div>


    <%- include("../partials/foot") %>