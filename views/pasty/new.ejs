                                    class="si-glyph-fill">

                                </path>
                                <path
                                    d="M3.758,2.359 L5.342,0.78 C5.342,0.4 5.031,0.093 4.651,0.093 L0.771,0.093 C0.39,0.093 0.081,0.4 0.081,0.78 L0.081,4.646 C0.081,5.027 0.391,5.334 0.771,5.334 L2.366,3.747 L4.335,5.715 C4.527,5.908 4.778,6.004 5.029,6.004 C5.282,6.004 5.532,5.908 5.725,5.715 C6.108,5.332 6.108,4.709 5.725,4.326 L3.758,2.359 L3.758,2.359 Z"
