<%- include("../partials/head", {title:"Create new Pasty"}) %>


    <div class="container">
        <fieldset>
            <legend>Create new pasty</legend>
            <form method="POST" action="/new">
                <button class="fsb" title="Enter Fullscreen" type="button">
